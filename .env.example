# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_SHEETS_URL: URL del Web App de Google Apps Script para enviar registros a Google Sheets.
# Para obtener esta URL:
# 1. Crea un Google Sheet.
# 2. Ve a Extensiones > Apps Script.
# 3. Pega el código proporcionado para recibir los datos.
# 4. Haz clic en Implementar > Nueva implementación > Tipo: Aplicación web.
# 5. Acceso: "Cualquier persona". Copia la URL generada y pégala aquí.
VITE_GOOGLE_SHEETS_URL=""

# VITE_GOOGLE_CLIENT_ID: ID de cliente de Google OAuth para la integración con Google Drive y Sheets.
# Obtén esto en la Consola de Google Cloud (https://console.cloud.google.com/apis/credentials).
VITE_GOOGLE_CLIENT_ID=""
